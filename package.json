{
  "name": "martol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && paraglide-js compile --outdir ./src/lib/paraglide && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && paraglide-js compile --outdir ./src/lib/paraglide && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "cf:dev": "node scripts/pg-tls-proxy.mjs & set -a && . ./.dev.vars && set +a && CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=\"postgres://$PG_USER:$PG_PASSWORD@127.0.0.1:5434/$PG_DATABASE\" wrangler dev; kill %1 2>/dev/null",
    "cf:deploy": "wrangler deploy",
    "cap:build": "CAPACITOR=true vite build",
    "cap:sync": "CAPACITOR=true vite build && cap sync",
    "cap:ios": "CAPACITOR=true vite build && cap sync && cap open ios",
    "cap:android": "CAPACITOR=true vite build && cap sync && cap open android"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.5.3",
    "@better-auth/drizzle-adapter": "^1.5.3",
    "@better-auth/passkey": "^1.5.3",
    "@capacitor/android": "^8.1.0",
    "@capacitor/core": "^8.0.2",
    "@capacitor/ios": "^8.1.0",
    "@inlang/paraglide-js": "^2.6.0",
    "@lucide/svelte": "^0.575.0",
    "better-auth": "^1.5.3",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "drizzle-orm": "^0.44.0",
    "marked": "^17.0.3",
    "pg": "^8.13.1",
    "stripe": "^20.4.0",
    "svelte": "^5.46.0",
    "tailwind-merge": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.2",
    "@cloudflare/workers-types": "^4.20250214.0",
    "@sveltejs/adapter-cloudflare": "^6.0.0",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.49.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/svelte": "^5.3.1",
    "@types/pg": "^8.11.11",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.0",
    "jsdom": "^28.1.0",
    "svelte-check": "^4.1.5",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vitest": "^4.0.18",
    "wrangler": "^4.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
